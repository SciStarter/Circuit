{
  "db_name": "PostgreSQL",
  "query": "select id, opportunity, first, latest, mode, participant, \"location\"\nfrom c_involvement\nwhere\n  participant = $1\nand\n  case\n    when $2::integer is null then mode >= 1\n    else mode >= greatest($2::integer, 1)\n  end\nand\n  case\n    when $3::integer is null then true\n    else mode <= $3::integer\n  end\norder by updated desc\nlimit $4 offset $5;\n",
